# ANTHROPIC_API_KEY — required for the Nura chatbot (server-side, Express).
# Obtain at https://console.anthropic.com/settings/keys
# Set in Railway: service → Variables tab.
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# RESEND_API_KEY — required to deliver chatbot enquiry emails to Petrina.
# Obtain at https://resend.com (free tier: 100 emails/day, 3k/month).
# If unset, enquiries are logged to the function log instead of emailed.
RESEND_API_KEY=""

# ENQUIRY_FROM_EMAIL — sender address for enquiry emails.
# Must be from a Resend-verified domain. Example:
# "Nuren Group Website <enquiries@nurengroup.com>"
# If unset, falls back to "Nuren Group Website <onboarding@resend.dev>" (Resend sandbox — only delivers to the Resend account owner; configure a real domain before production).
ENQUIRY_FROM_EMAIL=""

# APP_URL — public URL where this site is hosted.
APP_URL="MY_APP_URL"
